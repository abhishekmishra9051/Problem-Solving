# Ignore IntelliJ IDEA specific files
.idea/
*.iml

# Ignore compiled Java class files
/out/
/target/

# Ignore log files
*.log

# Ignore OS-specific files
.DS_Store  # macOS
Thumbs.db  # Windows

# Ignore Maven and Gradle build directories
/.mvn/
/.gradle/
/build/

# Ignore other IDE-specific files (Eclipse, etc.)
.project
.classpath
.settings/

# Ignore files generated by package managers
node_modules/

# Ignore temporary files created by the OS or IDE
*.swp  # Vim swap files
*.bak  # Backup files